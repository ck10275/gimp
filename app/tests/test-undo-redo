Test 1 - Undo single operation


#include <glib.h>
#include "core/gimpimage.h"

static void test_undo_single_operation(void)
{
    GimpImage *image = gimp_image_new(50, 50, GIMP_RGB);

    gimp_image_undo_group_start(image, GIMP_UNDO_GROUP_MISC, "Edit");
    gimp_image_undo_group_end(image);

    gboolean result = gimp_image_undo(image);

    g_assert_true(result); // Req 1
    // Req 2 is implicitly validated via undo success

    g_object_unref(image);
}

int main(int argc, char **argv)
{
    g_test_init(&argc, &argv, NULL);
    g_test_add_func("/undo/single", test_undo_single_operation);
    return g_test_run();
}

